def _compute_J_for_g(cfg, tau0, tau_int, a_pp_for_chi, g, omega_min, omega_max):
    return compute_chi_and_J(cfg, tau0, tau_int, a_pp_for_chi, g, omega_min, omega_max, cfg.delta_t)

def _calibrate_g_search(cfg, tau0, tau_int, a_pp_for_chi, g_seed, omega_min, omega_max):
    pts = max(5, int(cfg.g_calib_points))
    base = float(g_seed)
    width = max(cfg.g_calib_width_factor * max(1.0, abs(base)), 1.0)
    width = min(width, cfg.g_calib_abs_max)
    g_grid = np.linspace(base - width, base + width, pts)
    best = None
    best_res = None
    best_obj = np.inf
    for gv in g_grid:
        res = _compute_J_for_g(cfg, tau0, tau_int, a_pp_for_chi, gv, omega_min, omega_max)
        flatg = res.get('flatness_g', np.inf)
        chiavg = res.get('chi_avg_weighted', np.inf)
        obj = cfg.w_flatness * (abs(flatg) if np.isfinite(flatg) else 1e9) + cfg.w_chiavg  * (abs(chiavg - 1.0) if np.isfinite(chiavg) else 1e9)
        if obj < best_obj and np.isfinite(obj):
            best_obj = obj
            best = gv
            best_res = res
    if best is None or best_res is None:
        best = base
        best_res = _compute_J_for_g(cfg, tau0, tau_int, a_pp_for_chi, best, omega_min, omega_max)
    return float(best), best_res, float(best_obj)

def run_window(cfg: TheoryConfig, win_idx: int):
    v_th, p_th, epsilon, beta, tau0, tau_int = basic_scales(cfg)
    if cfg.v_eff_mode not in ("loc", "th"):
        raise ValueError("v_eff_mode must be 'loc' or 'th'")
    a_xx_bg, a_pp_bg = a_xx_a_pp_profiles(cfg, tau0, p_th, use_total=False)
    a_xx_tot, a_pp_tot = a_xx_a_pp_profiles(cfg, tau0, p_th, use_total=True)
    taus_bg, sig_bg = sigma_diff2_profile(tau_int, beta, a_xx_bg, a_pp_bg,
                                          n_steps=600, coeff_xx=cfg.kernel_sigma_xx_factor)
    taus_tot, sig_tot = sigma_diff2_profile(tau_int, beta, a_xx_tot, a_pp_tot,
                                            n_steps=600, coeff_xx=cfg.kernel_sigma_xx_factor)
    sigma_state_dimless_max = float(np.sqrt(max(epsilon**2 + np.max(sig_tot), 0.0)))
    sigma_psf_phys = float(cfg.psf_width)
    sigma_state_phys_max = cfg.L_v * sigma_state_dimless_max
    sigma_G_phys_max = np.sqrt(sigma_psf_phys**2 + sigma_state_phys_max**2)
    if cfg.v_eff_mode == "loc":
        v_eff = max(abs(cfg.v_loc), 1e-30)
    else:
        v_eff = max(v_th, 1e-30)
    omega_min = max(1.0/cfg.delta_t, v_eff/max(cfg.L_v, 1e-30))
    omega_candidates = [
        float(cfg.omega_sys),
        float(cfg.c_kappa) / max(cfg.delta_t, 1e-30),
        v_eff / max(sigma_G_phys_max, 1e-30)
    ]
    omega_max = float(min([c for c in omega_candidates if np.isfinite(c) and c > 0.0] + [np.inf]))
    valid_band = np.isfinite(omega_max) and (omega_max > omega_min)
    log_term = np.log(omega_max / omega_min) if valid_band else 0.0
    xi0 = cfg.x0 / max(cfg.L_v, 1e-30)
    vloc_abs = max(abs(cfg.v_loc), 1e-30)
    if cfg.baseline_gaussian_A_eff:
        L_eff = np.sqrt(cfg.L_v**2 + cfg.psf_width**2)
        A_eff = (cfg.L_v / max(L_eff, 1e-30)) * (cfg.V0_J / (p_th * vloc_abs))
        def d3Vtilde(xi):
            return A_eff * (12.0 * xi - 8.0 * xi**3) * np.exp(-xi**2)
    else:
        s = cfg.L_v / max(cfg.psf_width, 1e-30)
        A = (cfg.V0_J / (p_th * vloc_abs)) / np.sqrt(np.pi)
        def d3Vtilde(xi):
            return A * (-2.0 * (s**3) + 4.0 * (s**5) * (xi**2)) * np.exp(-(s**2) * (xi**2))
    K_val, xi_grid_g, G_g, d3_g, C_K_val, A0_val = compute_K_via_PSF(
        cfg, epsilon, xi0, d3Vtilde, sigma_state_dimless=sigma_state_dimless_max
    )
    J = np.nan; J_F = np.nan; J_cal1 = np.nan; J_used = np.nan
    chi_avg = np.nan; flatness = np.nan; flatness_g = np.nan; g_val = np.nan
    Jres = {'taus': None, 'chi_t': None, 'Tchi_dimless': 0.0, 'Tchi_phys': 0.0, 'norm_deta3_w': 0.0, 'bilateral': True,
            'denom': np.nan, 'denom_ref': np.nan, 'denom_rel_err': np.nan, 'J_consistency_rel_err': np.nan}
    if cfg.compute_J and valid_band:
        f_a_pp = a_pp_tot(0.0) if cfg.chi_use_total else a_pp_bg(0.0)
        sigma_psf = max(cfg.psf_width / max(cfg.L_v, 1e-30), 1e-12)
        xi_grid = np.linspace(xi0 - 12.0 * sigma_psf, xi0 + 12.0 * sigma_psf, 4001)
        G = psf_profile(cfg, xi_grid, xi0, sigma_psf)
        if cfg.baseline_gaussian_A_eff:
            d3_vals = A_eff * (12.0 * xi_grid - 8.0 * (xi_grid**3)) * np.exp(-xi_grid**2)
            g_auto = estimate_g_psf_weighted(xi_grid, G, True, A_eff, None, d3_vals)
        else:
            s = cfg.L_v / max(cfg.psf_width, 1e-30)
