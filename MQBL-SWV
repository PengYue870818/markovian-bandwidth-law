def basic_scales(cfg: TheoryConfig):
    v_th = np.sqrt(K_B * cfg.T / max(cfg.m, 1e-300))
    p_th = cfg.m * v_th
    epsilon = HBAR / max(cfg.L_v * p_th, 1e-300)
    tau0 = cfg.L_v / max(abs(cfg.v_loc), 1e-30)
    beta = max(abs(cfg.v_loc) / max(v_th, 1e-30), 1e-12)
    tau_int = cfg.delta_t / tau0
    return v_th, p_th, epsilon, beta, tau0, tau_int

def Lambda_coll(cfg: TheoryConfig):
    k = (2.0 * np.pi) / max(cfg.lambda_opt, 1e-30)
    return max(cfg.alpha_coll, 0.0) * (k**2) * max(cfg.Gamma_s_const, 0.0) * max(cfg.kappa_phi_sq, 0.0)

def Dpp_total(cfg: TheoryConfig):
    return max(cfg.Dpp_bg, 0.0) + 0.5 * (HBAR**2) * max(Lambda_coll(cfg), 0.0)

def Dxx_total(cfg: TheoryConfig):
    return max(cfg.Dxx_bg, 0.0)

def a_xx_a_pp_profiles(cfg: TheoryConfig, tau0, p_th, use_total=True):
    if use_total:
        Dpp = Dpp_total(cfg)
        Dxx = Dxx_total(cfg)
    else:
        Dpp = max(cfg.Dpp_bg, 0.0)
        Dxx = max(cfg.Dxx_bg, 0.0)
    a_pp = (Dpp * tau0) / max(p_th**2, 1e-300)
    a_xx = (Dxx * tau0) / max(cfg.L_v**2, 1e-300)
    def a_pp_tau(_tau):
        return a_pp
    def a_xx_tau(_tau):
        return a_xx
    return a_xx_tau, a_pp_tau

def sigma_diff2_profile(tau_int, beta, a_xx_tau, a_pp_tau, n_steps=600, coeff_xx=1.0):
    taus = np.linspace(0.0, float(tau_int), int(max(n_steps, 2)))
    d_tau = taus[1] - taus[0]
    a_xx_vals = np.array([a_xx_tau(t) for t in taus])
    a_pp_vals = np.array([a_pp_tau(t) for t in taus])
    int_xx = np.cumsum(a_xx_vals) * d_tau * float(coeff_xx)
    int_pp = np.zeros_like(taus)
    for i, tau in enumerate(taus):
        s = taus[:i+1]
        app = a_pp_vals[:i+1]
        weights = (tau - s)
        int_pp[i] = (2.0 / max(beta**2, 1e-30)) * np.sum(weights * app) * d_tau
    return taus, int_xx + int_pp

def _psf_profile(xi, mu, sigma, mode):
    if mode == "L1":
        coef = 1.0 / (np.sqrt(2.0*np.pi) * max(sigma, 1e-30))
        return coef * np.exp(- ((xi - mu) ** 2) / max(2.0 * sigma * sigma, 1e-300))
    coef = (np.pi ** (-0.25)) * (sigma ** (-0.5))
    return coef * np.exp(- ((xi - mu) ** 2) / max(2.0 * sigma * sigma, 1e-300))

def psf_profile(cfg: TheoryConfig, xi, mu, sigma):
    return _psf_profile(xi, mu, sigma, cfg.psf_norm_mode)

def compute_K_via_PSF(cfg: TheoryConfig, epsilon, xi0, d3Vtilde_func, sigma_state_dimless=None):
    C_K = 1.0 / (8.0 * np.sqrt(np.pi))
    sigma_psf = max(cfg.psf_width / max(cfg.L_v, 1e-30), 1e-12)
    mu = xi0
    xi_grid = np.linspace(mu - 12.0 * sigma_psf, mu + 12.0 * sigma_psf, 4001)
    G = psf_profile(cfg, xi_grid, mu, sigma_psf)
    if cfg.psf_matched:
        A0 = (15.0 / 48.0)
    else:
        sigma_state = float(max(sigma_state_dimless if sigma_state_dimless is not None else epsilon, 1e-12))
        n0 = _psf_profile(xi_grid, mu, sigma_state, cfg.psf_norm_mode)
        A0 = (15.0 / 48.0) * float(np.trapezoid(G * n0, xi_grid))
    d3V_vals = d3Vtilde_func(xi_grid)
    inner = float(np.trapezoid(G * d3V_vals, xi_grid))
    K = C_K * A0 * inner
    return K, xi_grid, G, d3V_vals, C_K, A0

def estimate_g_psf_weighted(xi_grid, G, baseline_gaussian, A_eff, s_scale, d3V_vals):
    if baseline_gaussian:
        d1_vals = -2.0 * A_eff * xi_grid * np.exp(-xi_grid**2)
    else:
        d2 = integrate.cumtrapz(d3V_vals, xi_grid, initial=0.0)
        d1_vals = integrate.cumtrapz(d2, xi_grid, initial=0.0)
    num = float(np.trapezoid(G * d1_vals, xi_grid))
    den = float(np.trapezoid(G, xi_grid))
    return num / max(den, 1e-30)

def V3_L2_norm(d3Vtilde_func, xi_min, xi_max, n=8001):
    xi = np.linspace(xi_min, xi_max, n)
    y = d3Vtilde_func(xi)
    return float(np.sqrt(np.trapezoid(y*y, xi)))

def compute_chi_and_J(cfg: TheoryConfig, tau0, tau_int, f_a_pp, g_dimless,
                      omega_min, omega_max, delta_t):
    N = int(cfg.J_n_eta)
    L = 2.0 * float(cfg.J_eta_max)
    d_eta = L / N
    eta = np.linspace(-L/2.0, -L/2.0 + (N-1)*d_eta, N)
    k = 2.0 * np.pi * np.fft.fftfreq(N, d=d_eta)
    phi = (1.0 / np.sqrt(2.0*np.pi)) * np.exp(-0.5 * eta**2)
    He3 = eta**3 - 3.0*eta
    w = phi * He3
    w_hat = np.fft.fft(w)
    der_hat_w0 = (1j * k)**3 * w_hat
    der_w0 = np.fft.ifft(der_hat_w0).real
    denom = float(np.trapezoid(phi * der_w0, eta))
    der_hat_w = (1j * k)**3 * w_hat
    d3w = np.fft.ifft(der_hat_w).real
    norm_deta3_w = float(np.sqrt(np.trapezoid(d3w*d3w, eta)))
    C_K_eta = 1.0 / (8.0 * np.sqrt(np.pi))
    denom_ref = (15.0/2.0) * C_K_eta
    denom_rel_err = np.nan
    if abs(denom_ref) > 0.0:
        denom_rel_err = abs(denom - denom_ref) / abs(denom_ref)
    if abs(denom) < 1e-20:
        return {
            'J': np.nan, 'J_F': np.nan, 'chi_avg_weighted': np.nan,
            'flatness': np.nan, 'flatness_g': np.nan,
            'omega_grid': None, 'chi_hat_vals_pos': None, 'chi_hat_vals_neg': None,
            'taus': None, 'chi_t': None, 'Tchi_dimless': np.nan, 'Tchi_phys': np.nan,
            'norm_deta3_w': norm_deta3_w, 'bilateral': True,
            'denom': denom, 'denom_ref': denom_ref, 'denom_rel_err': denom_rel_err,
            'J_consistency_rel_err': np.nan
        }
    Nt = int(max(cfg.J_n_t, 2))
    taus = np.linspace(0.0, float(tau_int), Nt)
    d_tau = taus[1] - taus[0]
    chi_tau = np.zeros_like(taus, dtype=np.float64)
    for j, tau in enumerate(taus):
        if tau == 0.0:
            chi_tau[j] = 1.0
        else:
            damp = np.exp(- f_a_pp * tau * (k**2)) * np.exp(-1j * g_dimless * tau * k)
            u_hat = damp * w_hat
            der_hat = (1j * k)**3 * u_hat
            der = np.fft.ifft(der_hat).real
            num = float(np.trapezoid(phi * der, eta))
            chi_tau[j] = num / denom
    Tchi_dim = float(np.trapezoid((tau_int - taus) * np.abs(chi_tau), taus))
    Tchi_phys = float((tau0**2) * Tchi_dim)
    if not (np.isfinite(omega_min) and np.isfinite(omega_max) and omega_max > omega_min):
        return {
            'J': np.nan, 'J_F': np.nan, 'chi_avg_weighted': np.nan,
            'flatness': np.nan, 'flatness_g': np.nan,
            'omega_grid': None, 'chi_hat_vals_pos': None, 'chi_hat_vals_neg': None,
            'taus': taus, 'chi_t': chi_tau, 'Tchi_dimless': Tchi_dim, 'Tchi_phys': Tchi_phys,
            'norm_deta3_w': norm_deta3_w, 'bilateral': True,
            'denom': denom, 'denom_ref': denom_ref, 'denom_rel_err': denom_rel_err,
            'J_consistency_rel_err': np.nan
        }
    n_om = 600
    ln_om = np.linspace(np.log(omega_min), np.log(omega_max), n_om)
    om = np.exp(ln_om)
    w_tau = np.ones(Nt)
    if Nt > 1:
        w_tau[0] = 0.5
        w_tau[-1] = 0.5
    phase_pos = np.exp(1j * np.outer(om * tau0, taus))
    chi_hat_pos = tau0 * (phase_pos @ (chi_tau * w_tau * d_tau))
    phase_neg = np.exp(1j * np.outer((-om) * tau0, taus))
    chi_hat_neg = tau0 * (phase_neg @ (chi_tau * w_tau * d_tau))
    F_pos = filter_rectangular_double_sided(om, delta_t)
    omegaF_pos = om * F_pos
    span = max(np.log(omega_max/omega_min), 1e-30)
    def log_avg(y):
        return float(np.trapezoid(y, ln_om) / span)
    J_F = (1.0 / (2.0*np.pi)) * (log_avg(omegaF_pos) + log_avg(omegaF_pos))
    num_avg = np.trapezoid(omegaF_pos * chi_hat_pos, ln_om) + np.trapezoid(omegaF_pos * chi_hat_neg, ln_om)
    den_avg = np.trapezoid(omegaF_pos, ln_om) + np.trapezoid(omegaF_pos, ln_om)
    chi_avg_weighted = (num_avg / max(den_avg, 1e-30)).real
    J = (1.0 / (2.0*np.pi)) * (num_avg.real / span)
    J_consistency_rel_err = np.nan
    if np.isfinite(J) and np.isfinite(J_F) and np.isfinite(chi_avg_weighted):
        ref = J_F * chi_avg_weighted
        if abs(ref) > 0:
            J_consistency_rel_err = abs(J - ref) / abs(ref)
    chi_hat_norm = chi_hat_pos / max(chi_avg_weighted, 1.0e-30)
    flatness = float(np.max(np.abs(chi_hat_norm - 1.0)))
    g_weight = (omegaF_pos * chi_hat_pos.real) / max(log_avg(omegaF_pos * chi_hat_pos.real), 1e-30)
    flatness_g = float(np.max(np.abs(g_weight - 1.0)))
    return {
        'J': float(J), 'J_F': float(J_F), 'chi_avg_weighted': float(chi_avg_weighted),
        'flatness': flatness, 'flatness_g': flatness_g,
        'omega_grid': om, 'chi_hat_vals_pos': chi_hat_pos, 'chi_hat_vals_neg': chi_hat_neg,
        'taus': taus, 'chi_t': chi_tau, 'Tchi_dimless': Tchi_dim, 'Tchi_phys': Tchi_phys,
        'norm_deta3_w': norm_deta3_w, 'bilateral': True,
        'denom': float(denom), 'denom_ref': float(denom_ref), 'denom_rel_err': float(denom_rel_err),
        'J_consistency_rel_err': float(J_consistency_rel_err)
    }

def finite_all(val):
    try:
        if np.isscalar(val):
            return np.isfinite(val)
        arr = np.asarray(val, dtype=float)
        return np.all(np.isfinite(arr))
    except Exception:
        return False

def validity_checks(cfg: TheoryConfig, epsilon, tau0, v_th, p_th,
                    sigma_G_phys_max, a_pp_val, a_xx_val, Jres,
                    slopeF_sup):
    cond_eps = (epsilon <= 0.2)
    ell_c = HBAR / np.sqrt(max(cfg.m * K_B * cfg.T, 1e-300))
    ell_eff = min(ell_c, cfg.L_v)
    Lam = Lambda_coll(cfg)
    Gamma_tot = cfg.Gamma_phi_bg + 0.5 * Lam * (ell_eff**2)
    cond_gamma = (Gamma_tot * cfg.delta_t <= 0.1)
    if np.isfinite(cfg.tau_mem) and cfg.tau_mem > 0.0:
        cond_taumem = ((cfg.tau_mem / cfg.delta_t) <= 0.1)
        tau_mem_ratio = cfg.tau_mem / cfg.delta_t
    else:
        cond_taumem = False
        tau_mem_ratio = np.nan
    if np.isfinite(cfg.c_rel_rate) and cfg.c_rel_rate >= 0.0:
        cond_slowc = (cfg.c_rel_rate * cfg.delta_t <= 0.1)
        c_rel = cfg.c_rel_rate * cfg.delta_t
    else:
        cond_slowc = False
        c_rel = np.nan
    if np.isfinite(cfg.sigmaG_rel_rate) and cfg.sigmaG_rel_rate >= 0.0:
        cond_sigma = (cfg.sigmaG_rel_rate * cfg.delta_t <= 0.1)
        sigma_rel = cfg.sigmaG_rel_rate * cfg.delta_t
    else:
        cond_sigma = True
        sigma_rel = 0.0
    cond_diff = ((a_pp_val <= 0.5) and (a_xx_val <= 0.5))
    flat = Jres.get('flatness', np.nan)
    flat_g = Jres.get('flatness_g', np.nan)
    cond_flat = (np.isfinite(flat) and np.isfinite(flat_g) and (flat <= 0.2) and (flat_g <= 0.2))
    cond_slopeF = (np.isfinite(slopeF_sup) and (slopeF_sup <= cfg.slope_thresh))
    checks = [
        ("epsilon <= 0.2", cond_eps, epsilon, 0.2),
        ("Gamma_tot*Delta_t << 1", cond_gamma, Gamma_tot*cfg.delta_t, 0.1),
        ("tau_mem/Delta_t << 1", cond_taumem, tau_mem_ratio, 0.1),
        ("max_c |dot c/c| Delta_t << 1", cond_slowc, c_rel, 0.1),
        ("|dot sigma_G| Delta_t/sigma_G << 1", cond_sigma, sigma_rel, 0.1),
        ("tilde a_pp, tilde a_xx <= 0.5", cond_diff, (a_pp_val, a_xx_val), 0.5),
        ("spectral flatness small", cond_flat, (flat, flat_g), 0.2),
        ("sup|dlog(omegaF)/dlog(omega)| small", cond_slopeF, slopeF_sup, cfg.slope_thresh)
    ]
    return checks

def fig_prefix(outdir, win_idx, tag):
    return os.path.join(outdir, f"w{win_idx:02d}_{tag}")

def queue_fig(fig, path):
    ensure_dir(os.path.dirname(path))
    PENDING_FIGS.append((fig, path))

def flush_all_figs():
    for fig, path in PENDING_FIGS:
        fig.savefig(path, dpi=200)
        fig.clf()
        plt.close(fig)
    PENDING_FIGS.clear()

def plot_overview(cfg, win_idx, K_val, log_term, J, J_F, J_cal1, J_used, flat, flat_g, delta_p1_main, bilateral):
    outdir = ensure_dir(cfg.outdir)
    fig = plt.figure(figsize=(8.4, 4.8))
    labels = ['K', 'ln_band', 'J', 'J_F', 'J_cal1', 'J_used', 'flat', 'flat_g']
    vals = [K_val, log_term, J, J_F, J_cal1, J_used, flat, flat_g]
    colors = ['#4C78A8', '#F58518', '#E45756', '#72B7B2', '#B279A2', '#9C755F', '#54A24B', '#EECA3B']
    plt.bar(labels, vals, color=colors)
    plt.ylabel('value')
    plt.title(f'[{win_idx}] Geometry-Window Overview')
    plt.tight_layout()
    png = fig_prefix(cfg.outdir, win_idx, "0_overview.png")
    csvp = fig_prefix(cfg.outdir, win_idx, "0_overview.csv")
    queue_fig(fig, png)
    save_csv(csvp,
             ['label', 'value', 'psf_norm', 'integral_branch', 'calibrated_branch', 'bilateral', 'note'],
             [labels, vals, cfg.psf_norm_mode, 'bilateral', int(cfg.enable_calibration), int(bool(bilateral)),
              'J_cal1=J/J_F; J_used includes optional chi_avg or unity-forcing'])

def plot_spectral(cfg, win_idx, omega_min, omega_max, Jres, J, J_F):
    if Jres.get('omega_grid') is None:
        return
    outdir = ensure_dir(cfg.outdir)
    om = Jres['omega_grid']
    ch_pos = Jres['chi_hat_vals_pos']
    F = filter_rectangular_double_sided(om, cfg.delta_t)
    mask = (om >= omega_min) & (om <= omega_max)
    omp = om[mask]
    Fm = F[mask]
    ch = ch_pos[mask]
    ln_om = np.log(omp)
    span = max(np.log(omega_max/omega_min), 1e-30)
    def log_avg(y):
        return float(np.trapezoid(y, ln_om) / span)
