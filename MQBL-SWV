def ensure_dir(d):
    if not os.path.isdir(d):
        os.makedirs(d, exist_ok=True)
    return d

def save_csv(path, headers, columns):
    arrays = []
    lens = []
    for c in columns:
        if np.isscalar(c) and not isinstance(c, str):
            arr = np.array([c])
        else:
            arr = np.array(c, dtype=object).reshape(-1)
        arrays.append(arr)
        lens.append(arr.shape[0])
    n = max(lens) if lens else 0
    bcols = []
    for arr in arrays:
        if arr.shape[0] == n:
            bcols.append(arr)
        elif arr.shape[0] == 1 and n > 1:
            bcols.append(np.full(n, arr[0], dtype=object))
        else:
            bcols.append(arr)
    with open(path, "w", newline="") as f:
        w = csv.writer(f)
        w.writerow(headers)
        for i in range(n):
            row = []
            for col in bcols:
                val = col[i]
                try:
                    row.append(float(val))
                except (TypeError, ValueError):
                    row.append(str(val))
            w.writerow(row)

def filter_rectangular_double_sided(omega, delta_t):
    x = 0.5 * omega * float(delta_t)
    denom = np.maximum(omega**2, 1e-300)
    return 4.0 * (np.sin(x)**2) / denom

