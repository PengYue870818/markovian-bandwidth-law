def attenuation_weights(cfg: TheoryConfig, v_th):
    ell_c = HBAR / np.sqrt(max(cfg.m * K_B * cfg.T, 1e-300))
    ell_eff = min(ell_c, cfg.L_v)
    Lam_coll = Lambda_coll(cfg)
    def Lambda_total_t(_t):
        return Lam_coll
    def Gamma_tot(Delta_x, t):
        return cfg.Gamma_phi_bg + 0.5 * Lambda_total_t(t) * (Delta_x**2)
    N = cfg.N_windows; dt = cfg.delta_t; gap = cfg.gap_time
    t_centers = [(k + 0.5)*dt + k*gap for k in range(N)]
    w = []
    cum = 0.0
    for k in range(N):
        cum += Gamma_tot(ell_eff, t_centers[k]) * dt
        w.append(np.exp(-cum))
        if k < N-1 and gap > 0.0:
            t_gap = (k+1)*dt + (k+0.5)*gap
            cum += (cfg.Gamma_phi_bg) * gap
    w = np.array(w, dtype=np.float64)
    N_eff = float(np.sum(w))
    N_eff2 = float(np.sum(w**2))
    return w, N_eff, N_eff2

def run_full_and_report(cfg: TheoryConfig):
    np.random.seed(cfg.seed)
    ensure_dir(cfg.outdir)
    print("="*120)
    print("Quantum Bandwidth Law (GKSL–Wigner, semiclassical) -- Markovian, paper-aligned")
    print(f"Conventions: PSF is {cfg.psf_norm_mode}-normalized in x; bilateral PSD; J_F is window-only factor;")
    print("            optional chi_avg calibration or forced-unity J_used for perfect calibration;")
    print("            denom check vs (15/2)C_K and J≈J_F*<chi> are logged.")
    print("="*120)
    results = []
    for k in range(cfg.N_windows):
        idx = k + 1
        res = run_window(cfg, idx)
        results.append(res)
    v_th, _, _, _, _, _ = basic_scales(cfg)
    w, N_eff, N_eff2 = attenuation_weights(cfg, v_th)
    print("="*120)
    print("Multi-window attenuation summary")
    print(f"N={cfg.N_windows}; gap_time={cfg.gap_time:.3e} s")
    print(f"weights={np.array2string(w, precision=3, separator=', ')}")
    print(f"N_eff={N_eff:.6e}; N_eff^(2)={N_eff2:.6e}")
    if len(results) > 0 and np.isfinite(results[0].get('delta_p1_main', np.nan)):
        dp1 = results[0]['delta_p1_main']
        print(f"delta_p_total(coherent) = {N_eff * dp1:.6e} kg*m/s")
        print(f"delta_p_total(RMS)      = {np.sqrt(N_eff2) * dp1:.6e} kg*m/s")
    print("="*120)
    flush_all_figs()

