def compute_s_slope(cfg: TheoryConfig, omega_min, omega_max):
    if cfg.s_omega_func is None:
        return np.nan, None, None
    n_om = 600
    ln_om = np.linspace(np.log(omega_min), np.log(omega_max), n_om)
    om = np.exp(ln_om)
    S = np.array([max(cfg.s_omega_func(float(o)), 1e-300) for o in om], dtype=float)
    y = np.log(S)
    dln = ln_om[1]-ln_om[0]
    dy = np.gradient(y, dln)
    supv = float(np.max(np.abs(dy)))
    return supv, om, dy

def compute_remainders(cfg: TheoryConfig, p_th, epsilon, delta_t,
                       V3_L2, Jres, lambda_eta, C_K, log_term, K_val):
    Tchi_dimless = Jres.get('Tchi_dimless', 0.0)
    Tchi_phys = Jres.get('Tchi_phys', 0.0)
    norm_deta3_w = Jres.get('norm_deta3_w', 0.0)
    E_p = p_th * (epsilon**2) * cfg.C_proj * C_K * Tchi_phys * cfg.rho_perp_L2 * V3_L2
    E_a = (p_th * (epsilon**2) * cfg.C_adj / 24.0) * ((4.0/15.0)*(delta_t**(2.5)) + (1.0/6.0)*(delta_t**3)) * cfg.W0_L2_sup * V3_L2
    piece1 = (delta_t / max(lambda_eta, 1e-30)) * cfg.W0_proj0_L2
    piece2 = (cfg.C_shape/2.0) * (delta_t**(2.5)) * cfg.N_xi_sup
    E_s = (p_th * (epsilon**2) / 24.0) * norm_deta3_w * (piece1 + piece2) * V3_L2
    E_f = cfg.C_freeze * p_th * (epsilon**2) * delta_t * Tchi_phys * (V3_L2 + cfg.n0_change_L2_sup)
    sup_g_minus_1 = Jres.get('flatness_g', 0.0)
    E_chi = cfg.c_chi * sup_g_minus_1 * p_th * (epsilon**2) * abs(K_val) * max(log_term, 0.0)
    return {'E_p': E_p, 'E_a': E_a, 'E_s': E_s, 'E_f': E_f, 'E_chi': E_chi,
            'Tchi_dimless': Tchi_dimless, 'Tchi_phys': Tchi_phys, 'norm_deta3_w': norm_deta3_w, 'sup_g_minus_1': sup_g_minus_1}

